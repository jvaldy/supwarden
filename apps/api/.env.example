# Modele de configuration locale pour l'application Symfony.
# Copier ce fichier vers `.env.local` ou injecter ces variables par l'environnement.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=__SET_LOCAL_APP_SECRET__
APP_AUTH_TOKEN_TTL=3600
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL=postgresql://__SET_LOCAL_DB_USER__:__SET_LOCAL_DB_PASSWORD__@127.0.0.1:5432/__SET_LOCAL_DB_NAME__?serverVersion=16&charset=utf8
###< doctrine/doctrine-bundle ###

###> symfony/mercure-bundle ###
MERCURE_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET=__SET_LOCAL_MERCURE_JWT_SECRET__
###< symfony/mercure-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
###> google/oauth ###
GOOGLE_OAUTH_CLIENT_ID=__SET_LOCAL_GOOGLE_OAUTH_CLIENT_ID__
GOOGLE_OAUTH_CLIENT_SECRET=__SET_LOCAL_GOOGLE_OAUTH_CLIENT_SECRET__
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback
GOOGLE_OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback
###< google/oauth ###

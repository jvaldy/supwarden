COMPOSE_PROJECT_NAME=supwarden_prod
APP_ENV=prod
APP_PORT=8000
WEB_PORT=5173
DB_PORT=5432
ADMINER_PORT=8080
MERCURE_PORT=3000

DATABASE_URL=postgresql://__SET_PROD_DB_USER__:__SET_PROD_DB_PASSWORD__@__SET_PROD_DB_HOST__:5432/__SET_PROD_DB_NAME__?serverVersion=16&charset=utf8

APP_SECRET=__SET_PROD_APP_SECRET__
MERCURE_JWT_SECRET=__SET_PROD_MERCURE_JWT_SECRET__
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000

GOOGLE_OAUTH_CLIENT_ID=__SET_PROD_GOOGLE_OAUTH_CLIENT_ID__
GOOGLE_OAUTH_CLIENT_SECRET=__SET_PROD_GOOGLE_OAUTH_CLIENT_SECRET__
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback
GOOGLE_OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

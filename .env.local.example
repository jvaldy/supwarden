# Copie ce fichier vers .env.local seulement si tu dois surcharger des valeurs de .env.
# Si tu laisses ce fichier vide, l'application reste demarrable avec .env.

# Exemple de surcharge locale :
# POSTGRES_PASSWORD=__SET_LOCAL_DB_PASSWORD__
# APP_SECRET=__SET_LOCAL_APP_SECRET__
# MERCURE_JWT_SECRET=__SET_LOCAL_MERCURE_JWT_SECRET__
# GOOGLE_OAUTH_CLIENT_ID=__SET_LOCAL_GOOGLE_OAUTH_CLIENT_ID__
# GOOGLE_OAUTH_CLIENT_SECRET=__SET_LOCAL_GOOGLE_OAUTH_CLIENT_SECRET__
